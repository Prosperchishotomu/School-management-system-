DB_HOST=localhost
DB_PORT=3306
DB_NAME=schoolbase
DB_USER=root
DB_PASS=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# JWT token expiry in seconds (default: 1800 = 30 minutes)
JWT_EXPIRY_SECONDS=1800

# Login brute-force protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=15

CORS_ALLOWED_ORIGIN=http://localhost:5173

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
# App URL used for generating password reset links
APP_URL=http://localhost
